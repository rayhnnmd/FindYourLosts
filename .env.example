# Database Configuration
MYSQL_HOST=your-mysql-host
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=your-mysql-db

# Flask Configuration
SECRET_KEY=your-long-random-secret-key
DEBUG=False
PORT=5000

# Email Configuration (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SENDER_NAME=FindYourLosts
MAIL_SENDER_EMAIL=your-email@gmail.com

# Firebase Service Account
# On Render, you can store the JSON content in a secret environment variable 
# and use a build script to write it to serviceAccountKey.json
# FIREBASE_CREDENTIALS_JSON='{...}'
